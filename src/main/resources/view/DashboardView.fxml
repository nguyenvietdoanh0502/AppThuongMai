<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="750.0" prefWidth="1200.0" spacing="0" style="-fx-background-color: #f5f6fa;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.AdminDashboardController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0"
              style="-fx-background-color: #2c3e50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
            <padding>
                <Insets left="25.0" right="25.0" />
            </padding>
            <children>
                <Label text="📊 HỆ THỐNG THỐNG KÊ" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#handleBackToAdmin"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"
                        text="⬅ QUAY LẠI QUẢN LÝ">
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                    </padding>
                </Button>
            </children>
        </HBox>

        <HBox prefHeight="50.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets left="20.0" top="5.0" />
            </padding>
            <children>
                <Button fx:id="btnNavRevenue" onAction="#switchView" text="DOANH THU" />
                <Button fx:id="btnNavProduct" onAction="#switchView" text="SẢN PHẨM" />
                <Button fx:id="btnNavCustomer" onAction="#switchView" text="KHÁCH HÀNG" />
            </children>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS">
            <children>
                <VBox fx:id="viewRevenue" spacing="20.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox spacing="20.0">
                            <children>
                                <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                                    <Label text="Tổng đơn hàng" textFill="#7f8c8d" />
                                    <Label fx:id="lblCount" text="0" style="-fx-font-size: 30; -fx-font-weight: bold;" />
                                </VBox>
                                <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 0);" HBox.hgrow="ALWAYS">
                                    <Label text="Tổng doanh thu" textFill="#7f8c8d" />
                                    <Label fx:id="lblSum" text="0$" style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                </VBox>
                            </children>
                        </HBox>
                        <BarChart fx:id="revenueChart" title="Biểu đồ doanh thu theo ngày" VBox.vgrow="ALWAYS">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </BarChart>
                    </children>
                </VBox>

                <VBox fx:id="viewProducts" spacing="20.0" visible="false">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="Top Sản Phẩm Bán Chạy (Số lượng)" style="-fx-font-weight: bold;" />
                                    <PieChart fx:id="productPieChart" />
                                </VBox>
                                <VBox alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="Top Doanh Thu Theo Sản Phẩm" style="-fx-font-weight: bold;" />
                                    <PieChart fx:id="revenuePieChart" />
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox fx:id="viewCustomers" spacing="15.0" visible="false">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <Label text="DANH SÁCH KHÁCH HÀNG THÂN THIẾT" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                        <TableView fx:id="tblCustomers" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUsername" prefWidth="250.0" text="Tên khách hàng" />
                                <TableColumn fx:id="colOrderCount" prefWidth="150.0" text="Số đơn đã mua" />
                                <TableColumn fx:id="colTotalSpent" prefWidth="200.0" text="Tổng chi tiêu ($)" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</VBox>