<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.TableColumn?>
<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.AdminDashboardController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 0, 5, 0, 0);">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <Label text="HOBBEE ADMIN">
                            <font><Font name="System Bold" size="24.0" /></font>
                            <HBox.margin><Insets right="30.0" /></HBox.margin>
                        </Label>

                        <Button fx:id="btnNavRevenue" mnemonicParsing="false" onAction="#switchView"
                                style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-scale-x: 1; -fx-scale-y: 1; -fx-background-insets: 0; -fx-padding: 10;"
                                text="DOANH THU" textFill="#555555">
                            <font><Font size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnNavProduct" mnemonicParsing="false" onAction="#switchView"
                                style="-fx-background-color: transparent; -fx-scale-x: 1; -fx-scale-y: 1; -fx-background-insets: 0; -fx-padding: 10;"
                                text="SẢN PHẨM BÁN CHẠY" textFill="#555555">
                            <font><Font size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnNavCustomer" mnemonicParsing="false" onAction="#switchView"
                                style="-fx-background-color: transparent; -fx-scale-x: 1; -fx-scale-y: 1; -fx-background-insets: 0; -fx-padding: 10;"
                                text="KHÁCH HÀNG" textFill="#555555">
                            <font><Font size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <StackPane VBox.vgrow="ALWAYS">
                    <children>
                        <VBox fx:id="viewRevenue" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="Thống kê doanh thu" textFill="#333333">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>

                                <HBox spacing="20.0">
                                    <children>
                                        <VBox prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                                            <children>
                                                <Label text="Tổng đơn hàng" textFill="#777777">
                                                    <font><Font size="14.0" /></font>
                                                </Label>
                                                <Label fx:id="lblCount" text="1,245" textFill="#2196f3">
                                                    <font><Font name="System Bold" size="24.0" /></font>
                                                </Label>
                                            </children>
                                            <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                                        </VBox>

                                        <VBox prefHeight="100.0" prefWidth="250.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
                                            <children>
                                                <Label text="Tổng doanh thu" textFill="#777777">
                                                    <font><Font size="14.0" /></font>
                                                </Label>
                                                <Label fx:id="lblSum" text="0" textFill="#4caf50">
                                                    <font><Font name="System Bold" size="24.0" /></font>
                                                </Label>
                                            </children>
                                            <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Biểu đồ doanh thu theo ngày">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                            <VBox.margin>
                                                <Insets bottom="10.0" left="20.0" top="15.0" />
                                            </VBox.margin>
                                        </Label>

                                        <BarChart fx:id="revenueChart" legendVisible="false" prefHeight="400.0" prefWidth="800.0" style="-fx-bar-fill: #4caf50;" VBox.vgrow="ALWAYS">
                                            <xAxis>
                                                <CategoryAxis label="Ngày" side="BOTTOM" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis label="Doanh thu ($)" side="LEFT" />
                                            </yAxis>
                                        </BarChart>
                                    </children>
                                    <padding>
                                        <Insets bottom="10.0" right="10.0" top="10.0" />
                                    </padding>
                                </VBox>

                            </children>
                        </VBox>

                        <VBox fx:id="viewProducts" spacing="20.0" style="-fx-background-color: #f4f4f4;" visible="false">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                            <children>
                                <Label text="Phân tích sản phẩm bán chạy" textFill="#333333">
                                    <font><Font name="System Bold" size="20.0" /></font>
                                </Label>

                                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox alignment="TOP_CENTER" style="-fx-background-color: white; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Theo Số Lượng" textFill="#777777">
                                                    <font><Font name="System Bold" size="14.0"/></font>
                                                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                                                </Label>
                                                <PieChart fx:id="productPieChart" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="TOP_CENTER" style="-fx-background-color: white; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Theo Doanh Thu" textFill="#777777">
                                                    <font><Font name="System Bold" size="14.0"/></font>
                                                    <VBox.margin><Insets top="10.0"/></VBox.margin>
                                                </Label>
                                                <PieChart fx:id="revenuePieChart" VBox.vgrow="ALWAYS" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <VBox fx:id="viewCustomers" visible="false" spacing="20.0" style="-fx-background-color: #f4f4f4;">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                            <children>
                                <Label text="Danh sách khách hàng" textFill="#333333">
                                    <font><Font name="System Bold" size="20.0" /></font>
                                </Label>

                                <TableView fx:id="tblCustomers" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colUsername" prefWidth="200.0" text="Tên đăng nhập" />
                                        <TableColumn fx:id="colOrderCount" prefWidth="100.0" text="Số đơn" />
                                        <TableColumn fx:id="colTotalSpent" prefWidth="150.0" text="Tổng chi tiêu ($)" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
