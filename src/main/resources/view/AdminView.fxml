<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<VBox prefHeight="750.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.AdminController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20.0"
              style="-fx-background-color: #2c3e50; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0);">
            <padding>
                <Insets left="25.0" right="25.0"/>
            </padding>
            <children>
                <Label text="HOBBEE" textFill="#3498db">
                    <font>
                        <Font name="System Bold" size="26.0"/>
                    </font>
                </Label>
                <Label text="| HỆ THỐNG QUẢN TRỊ" textFill="WHITE">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleOpenStatistics"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"
                        text="📊 XEM THỐNG KÊ">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                    </padding>
                </Button>
                <Button onAction="#handleLogout"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"
                        text="ĐĂNG XUẤT">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
                    </padding>
                </Button>
            </children>
        </HBox>

        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-tab-min-width: 150;">
            <tabs>
                <Tab text="📦 Quản lý Sản phẩm">
                    <content>
                        <SplitPane dividerPositions="0.65">
                            <items>
                                <VBox spacing="10.0">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0"
                                              style="-fx-background-color: white; -fx-padding: 8; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
                                            <children>
                                                <Label text="🔍" style="-fx-font-size: 16;"/>
                                                <TextField fx:id="txtSearchProduct"
                                                           promptText="Tìm theo tên hoặc danh mục sản phẩm..."
                                                           HBox.hgrow="ALWAYS"
                                                           style="-fx-background-color: transparent;"/>
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tableProducts" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID"/>
                                                <TableColumn fx:id="colTitle" prefWidth="220.0" text="Tên sản phẩm"/>
                                                <TableColumn fx:id="colPrice" prefWidth="90.0" text="Giá ($)"/>
                                                <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Số lượng"/>
                                                <TableColumn fx:id="colCategory" prefWidth="120.0" text="Danh mục"/>
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                                <VBox spacing="15.0" style="-fx-background-color: #ecf0f1;">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                                    </padding>
                                    <children>
                                        <Label text="THÔNG TIN SẢN PHẨM"
                                               style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                        <GridPane vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints prefWidth="100.0"/>
                                                <ColumnConstraints prefWidth="200.0"/>
                                            </columnConstraints>
                                            <children>
                                                <Label text="Tên sản phẩm:"/>
                                                <TextField fx:id="txtTitle" GridPane.columnIndex="1"/>
                                                <Label text="Giá bán:" GridPane.rowIndex="1"/>
                                                <TextField fx:id="txtPrice" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>
                                                <Label text="Số lượng:" GridPane.rowIndex="2"/>
                                                <TextField fx:id="txtQuantity" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="2"/>
                                                <Label text="Danh mục:" GridPane.rowIndex="3"/>
                                                <TextField fx:id="txtCategory" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="3"/>
                                                <Label text="Link ảnh:" GridPane.rowIndex="4"/>
                                                <HBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                                    <children>
                                                        <TextField fx:id="txtImage" HBox.hgrow="ALWAYS"
                                                                   promptText="URL hoặc file..."/>
                                                        <Button onAction="#handleChooseFile" text="📁"
                                                                style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </GridPane>
                                        <VBox alignment="CENTER" spacing="5"
                                              style="-fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-padding: 10; -fx-background-color: white;">
                                            <Label text="XEM TRƯỚC ẢNH"
                                                   style="-fx-font-size: 10; -fx-text-fill: #7f8c8d;"/>
                                            <ImageView fx:id="imgPreview" fitHeight="160.0" fitWidth="160.0"
                                                       pickOnBounds="true" preserveRatio="true"/>
                                        </VBox>
                                        <HBox spacing="10.0" alignment="CENTER">
                                            <Button onAction="#handleAdd" prefWidth="80.0" text="THÊM"
                                                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                            <Button onAction="#handleUpdate" prefWidth="80.0" text="SỬA"
                                                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                            <Button onAction="#handleDelete" prefWidth="80.0" text="XÓA"
                                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                        </HBox>
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>

                <Tab text="👥 Quản lý Người dùng">
                    <content>
                        <SplitPane dividerPositions="0.65">
                            <items>
                                <VBox spacing="10.0">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
                                    </padding>
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0"
                                              style="-fx-background-color: white; -fx-padding: 8; -fx-border-color: #dcdde1; -fx-border-radius: 5;">
                                            <children>
                                                <Label text="🔍"/>
                                                <TextField fx:id="txtSearchUser"
                                                           promptText="Tìm theo username hoặc email..."
                                                           HBox.hgrow="ALWAYS"
                                                           style="-fx-background-color: transparent;"/>
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colUserId" text="ID" prefWidth="50"/>
                                                <TableColumn fx:id="colUsername" text="Username" prefWidth="130"/>
                                                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                                                <TableColumn fx:id="colRole" text="Quyền" prefWidth="90"/>
                                                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                                <VBox spacing="15.0" style="-fx-background-color: #f4f7f6;">
                                    <padding>
                                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                                    </padding>
                                    <children>
                                        <Label text="QUẢN LÝ TÀI KHOẢN"
                                               style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                        <GridPane vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints prefWidth="100.0"/>
                                                <ColumnConstraints prefWidth="200.0"/>
                                            </columnConstraints>
                                            <children>
                                                <Label text="Username:"/>
                                                <TextField fx:id="txtUsername" GridPane.columnIndex="1"/>
                                                <Label text="Email:" GridPane.rowIndex="1"/>
                                                <TextField fx:id="txtEmail" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="1"/>
                                                <Label text="Mật khẩu:" GridPane.rowIndex="2"/>
                                                <TextField fx:id="txtPassword" GridPane.columnIndex="1"
                                                           GridPane.rowIndex="2"/>
                                                <Label text="Quyền hạn:" GridPane.rowIndex="3"/>
                                                <ComboBox fx:id="cbRole" prefWidth="200.0" GridPane.columnIndex="1"
                                                          GridPane.rowIndex="3"/>
                                            </children>
                                        </GridPane>
                                        <Separator/>
                                        <VBox spacing="10.0" alignment="CENTER">
                                            <HBox spacing="10.0" alignment="CENTER">
                                                <Button onAction="#handleLockUser" prefWidth="100.0" text="KHÓA TK"
                                                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                                <Button onAction="#handleUnlockUser" prefWidth="100.0" text="MỞ KHÓA"
                                                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                            </HBox>
                                            <Button onAction="#handleDeleteUser" text="XÓA VĨNH VIỄN" prefWidth="210.0"
                                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
                                        </VBox>
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>