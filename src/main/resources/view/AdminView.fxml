<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.AdminController">
    <children>
        <SplitPane dividerPositions="0.6" layoutX="10.0" layoutY="10.0" prefHeight="650.0" prefWidth="1100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <children>
                        <Label text="HỆ THỐNG QUẢN TRỊ SẢN PHẨM" textFill="#2c3e50">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <TableView fx:id="tableProducts" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="colTitle" prefWidth="180.0" text="Tên sản phẩm" />
                                <TableColumn fx:id="colPrice" prefWidth="90.0" text="Giá ($)" />
                                <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Số lượng" />
                                <TableColumn fx:id="colCategory" prefWidth="120.0" text="Danh mục" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>

                <VBox spacing="15.0" style="-fx-background-color: #ecf0f1;">
                    <children>
                        <Label text="CHI TIẾT SẢN PHẨM" textFill="#34495e">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <GridPane vgap="12.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" maxWidth="120.0" minWidth="10.0" prefWidth="90.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="35.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="Tiêu đề:" />
                                <TextField fx:id="txtTitle" prefHeight="30.0" GridPane.columnIndex="1" />

                                <Label text="Giá bán:" GridPane.rowIndex="1" />
                                <TextField fx:id="txtPrice" prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Số lượng:" GridPane.rowIndex="2" />
                                <TextField fx:id="txtQuantity" prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Danh mục:" GridPane.rowIndex="3" />
                                <TextField fx:id="txtCategory" prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Link ảnh:" GridPane.rowIndex="4" />
                                <TextField fx:id="txtImage" prefHeight="30.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Mô tả:" GridPane.rowIndex="5" />
                                <TextArea fx:id="txtDescription" prefHeight="100.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                            </children>
                        </GridPane>
                        <Separator prefWidth="200.0" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleAdd" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="THÊM" />
                                <Button mnemonicParsing="false" onAction="#handleUpdate" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" text="SỬA" />
                                <Button mnemonicParsing="false" onAction="#handleDelete" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="XÓA" />
                            </children>
                        </HBox>
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleClear" prefHeight="35.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" text="LÀM MỚI FORM" />
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>