<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="25" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.login_controller.ForgotPasswordController">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40"/>
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Label text="Reset Password" style="-fx-text-fill: #1F41BB; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        <Label fx:id="lblMessage" text="Enter your details to receive an OTP" textAlignment="CENTER"
               style="-fx-font-size: 14px; -fx-text-fill: #626262;" wrapText="true"/>
    </VBox>

    <VBox spacing="15" style="-fx-max-width: 350;">

        <VBox fx:id="step1Box" spacing="15">
            <TextField fx:id="txtUsername" prefHeight="55" promptText="Username"
                       style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #1F41BB; -fx-border-radius: 10; -fx-border-width: 1;"/>
            <TextField fx:id="txtEmail" prefHeight="55" promptText="Email"
                       style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #1F41BB; -fx-border-radius: 10; -fx-border-width: 1;"/>
            <Button maxWidth="Infinity" onAction="#handleSendOTP" prefHeight="55"
                    style="-fx-background-color: #1F41BB; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Send OTP"/>
        </VBox>

        <VBox fx:id="otpBox" managed="false" visible="false" spacing="15">
            <TextField fx:id="txtOTPInput" prefHeight="55" promptText="Enter 6-digit OTP"
                       style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #FF8C00; -fx-border-radius: 10; -fx-border-width: 1;"/>
            <Button maxWidth="Infinity" onAction="#handleVerifyOTP" prefHeight="55"
                    style="-fx-background-color: #FF8C00; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Verify OTP"/>
        </VBox>

        <VBox fx:id="step2Box" managed="false" visible="false" spacing="15">
            <StackPane>
                <PasswordField fx:id="txtNewPassword" prefHeight="55" promptText="New Password"
                               style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #28a745; -fx-border-radius: 10; -fx-border-width: 1;"/>
                <TextField fx:id="txtNewPasswordVisible" managed="false" visible="false" prefHeight="55"
                           promptText="New Password"
                           style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #28a745; -fx-border-radius: 10; -fx-border-width: 1;"/>
            </StackPane>

            <StackPane>
                <PasswordField fx:id="txtConfirmPassword" prefHeight="55" promptText="Confirm New Password"
                               style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #28a745; -fx-border-radius: 10; -fx-border-width: 1;"/>
                <TextField fx:id="txtConfirmPasswordVisible" managed="false" visible="false" prefHeight="55"
                           promptText="Confirm New Password"
                           style="-fx-background-color: #F1F4FF; -fx-background-radius: 10; -fx-border-color: #28a745; -fx-border-radius: 10; -fx-border-width: 1;"/>
            </StackPane>

            <CheckBox fx:id="checkShowPassword" text="Show Password" onAction="#handleTogglePassword"
                      style="-fx-text-fill: #626262; -fx-cursor: hand; -fx-font-size: 13px;"/>

            <Button maxWidth="Infinity" onAction="#handleResetPassword" prefHeight="55"
                    style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 10; -fx-cursor: hand;"
                    text="Update Password"/>
        </VBox>

        <Button onAction="#handleBackToLogin" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #494949; -fx-font-weight: bold; -fx-cursor: hand;"
                text="Back to Login"/>
    </VBox>
</VBox>