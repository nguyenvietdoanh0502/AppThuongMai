<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<AnchorPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.UserViewController">
    <GridPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">

        <columnConstraints>
            <ColumnConstraints fx:id="colSidebar" hgrow="NEVER" maxWidth="300.0" minWidth="200.0" prefWidth="250.0"/>

            <ColumnConstraints fx:id="colContent" hgrow="ALWAYS"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints maxHeight="80.0" minHeight="80.0" prefHeight="80.0" vgrow="NEVER"/>

            <RowConstraints vgrow="ALWAYS"/>
        </rowConstraints>

        <children>

            <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #ffffff;" GridPane.columnSpan="2">
                <children>
                    <ImageView fitHeight="61.0" fitWidth="112.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../asset/logoHobbee.png"/>
                        </image>

                    </ImageView>
                    <HBox alignment="CENTER" prefHeight="80.0" prefWidth="267.0" spacing="12.0">
                        <children>
                            <TextField fx:id="txtSearch" prefHeight="32.0" prefWidth="229.0"
                                       promptText="Nhập sản phẩm..."
                                       style="-fx-background-color: #ffffff; -fx-border-color: #000000; -fx-border-radius: 4;"/>
                            <FontIcon iconLiteral="fas-search" iconSize="24"/>
                        </children>
                    </HBox>
                    <HBox alignment="CENTER" prefHeight="80.0" prefWidth="142.0">
                        <children>
                            <Button mnemonicParsing="false" style="-fx-background-color: #ffffff;" text="Blog"/>
                            <Button mnemonicParsing="false" style="-fx-background-color: #ffffff;" text="Contact Us"/>
                        </children>
                    </HBox>
                    <HBox alignment="CENTER" prefHeight="80.0" prefWidth="275.0" spacing="16.0">
                        <children>
                            <FontIcon iconLiteral="fas-bell" iconSize="20"/>
                            <FontIcon iconLiteral="fas-heart" iconSize="20"/>
                            <StackPane fx:id="cartIconContainer" onMouseClicked="#toggleCart">
                                <children>
                                    <FontIcon iconLiteral="fas-shopping-bag" iconSize="20"/>

                                    <Label fx:id="lblCartCount" alignment="CENTER" minHeight="11.0" minWidth="9.0"
                                           prefHeight="11.0" prefWidth="9.0"
                                           style="-fx-background-color: #ff0000; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-min-width: 16px; -fx-min-height: 16px; -fx-max-height: 16px; -fx-max-width: 16px; -fx-padding: 0;"
                                           styleClass="cart-badge" text="2">
                                        <StackPane.margin>
                                            <Insets right="-8.0" top="-8.0"/>
                                        </StackPane.margin>
                                    </Label>
                                </children>
                            </StackPane>
                            <Button mnemonicParsing="false" prefHeight="30.0" prefWidth="76.0"
                                    style="-fx-background-color: #ffffff; -fx-border-radius: 4; -fx-border-color: #000000;"
                                    text="User"/>
                            <Button fx:id="lblLogout" onAction="#handleBtnLogout" mnemonicParsing="false"
                                    prefHeight="30.0" prefWidth="76.0"
                                    style="-fx-background-color: #000000; -fx-border-radius: 4;" text="Logout"
                                    textFill="WHITE"/>
                        </children>
                    </HBox>


                </children>
            </HBox>


            <VBox fx:id="sidebarFilter"
                  style="-fx-background-color: white; -fx-border-color: #eee; -fx-border-width: 0 1 0 0;"
                  GridPane.rowIndex="1">
                <children>
                    <VBox spacing="10.0" style="-fx-padding: 10;">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Categories">
                            <font>
                                <Font size="21.0"/>
                            </font>
                        </Label>
                        <VBox fx:id="categoryContainer" spacing="5.0">
                        </VBox>
                    </VBox>
                    <VBox prefHeight="56.0" prefWidth="209.0" spacing="10.0" style="-fx-padding: 10;">
                        <children>
                            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Prices">
                                <font>
                                    <Font size="21.0"/>
                                </font>
                            </Label>
                            <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                                <children>
                                    <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                                        <children>
                                            <Label text="Min:" textFill="#333333">
                                                <font>
                                                    <Font size="14.0"/>
                                                </font>
                                            </Label>
                                            <TextField fx:id="minPrice" promptText="Nhập giá nhỏ nhất..."/>
                                        </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                                        <children>
                                            <Label text="Max" textFill="#333333">
                                                <font>
                                                    <Font size="14.0"/>
                                                </font>
                                            </Label>
                                            <TextField fx:id="maxPrice" promptText="Nhập giá lớn nhất..."/>
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </children>
                <padding>
                    <Insets left="20" right="20" top="20"/>
                </padding>
            </VBox>


            <ScrollPane fx:id="contentArea" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <content>
                    <TilePane fx:id="productContainer" hgap="20.0" prefColumns="3" tileAlignment="TOP_LEFT" vgap="20.0">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>
                    </TilePane>
                </content>
            </ScrollPane>

        </children>
    </GridPane>
    <VBox fx:id="cartOverlay" visible="false"
          AnchorPane.rightAnchor="80.0" AnchorPane.topAnchor="70.0"
          prefWidth="360.0" maxHeight="500.0" spacing="0.0"
          style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-background-radius: 8; -fx-border-radius: 8;">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <children>
            <Label fx:id="lblOverlayHeader" style="-fx-font-size: 15px; -fx-text-fill: #333;">
                <VBox.margin>
                    <Insets bottom="15.0"/>
                </VBox.margin>
            </Label>

            <ScrollPane vbarPolicy="NEVER" fitToWidth="true" hbarPolicy="NEVER" prefHeight="300.0"
                        style="-fx-background-color: transparent; -fx-background: white; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="cartItemsContainer" spacing="0.0" style="-fx-background-color: white;"/>
                </content>
            </ScrollPane>

            <VBox spacing="12.0">
                <VBox.margin>
                    <Insets top="15.0"/>
                </VBox.margin>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Subtotal" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #000;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblSubtotal" text="99"
                           style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #000;"/>
                </HBox>


                <Button fx:id="btnCheckout" onAction="#handleCheckout" text="Checkout" maxWidth="Infinity"
                        style="-fx-background-color: #111; -fx-text-fill: white; -fx-background-radius: 4; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 9;"/>
            </VBox>
        </children>
    </VBox>
</AnchorPane>
