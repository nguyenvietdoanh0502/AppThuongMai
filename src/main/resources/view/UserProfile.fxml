<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f7f6;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.UserProfileController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
            </padding>
            <children>
                <VBox prefWidth="260.0" spacing="15.0">
                    <children>
                        <Button fx:id="btnBack" mnemonicParsing="false" prefHeight="40.0" prefWidth="260.0"
                                style="-fx-background-color: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);"
                                text="← Trở về trang chủ">
                            <font>
                                <Font name="System Bold" size="13.0"/>
                            </font>
                        </Button>

                        <VBox alignment="CENTER" spacing="10.0"
                              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                            <padding>
                                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0"/>
                            </padding>
                            <children>
                                <StackPane prefHeight="90.0" prefWidth="90.0"
                                           style="-fx-background-color: #f8f9fa; -fx-background-radius: 15; -fx-border-color: #eee; -fx-border-radius: 15;">
                                    <children>
                                        <ImageView fx:id="imgAvatar" fitHeight="80.0" fitWidth="80.0"
                                                   pickOnBounds="true"/>
                                    </children>
                                </StackPane>
                                <Label fx:id="lblSidebarName" text="Người dùng" textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="16.0"/>
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox spacing="5.0"
                              style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);"
                              VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                            </padding>
                            <children>
                                <Button fx:id="btnInfo" onAction="#switchView" prefHeight="45.0" prefWidth="240.0"
                                        text="👤 Thông tin cá nhân"/>
                                <Button fx:id="btnLike" onAction="#switchView" prefHeight="45.0" prefWidth="240.0"
                                        text="❤️ Sản phẩm yêu thích"/>
                                <Button fx:id="btnHistory" onAction="#switchView" prefHeight="45.0" prefWidth="240.0"
                                        text="📜 Lịch sử mua hàng"/>
                                <Button fx:id="btnDeposit" onAction="#switchView" prefHeight="45.0" prefWidth="240.0"
                                        text="💰 Nạp tiền tài khoản"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4);">
                    <children>
                        <VBox fx:id="viewInfo" spacing="20.0">
                            <padding>
                                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
                            </padding>
                            <children>
                                <Label text="Hồ sơ cá nhân">
                                    <font>
                                        <Font name="System Bold" size="22.0"/>
                                    </font>
                                </Label>
                                <GridPane hgap="20.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                    </columnConstraints>
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label text="Tên đăng nhập"/>
                                            <TextField fx:id="txtUsername" editable="false" prefHeight="40.0"/>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnIndex="1">
                                            <Label text="Vai trò"/>
                                            <TextField fx:id="txtRole" editable="false" prefHeight="40.0"/>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                            <Label text="Email"/>
                                            <TextField fx:id="txtEmail" editable="false" prefHeight="40.0"/>
                                        </VBox>
                                        <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="2">
                                            <Label text="Số dư hiện tại ($)"/>
                                            <TextField fx:id="txtMoney" editable="false" prefHeight="50.0"
                                                       style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #27ae60;"/>
                                        </VBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox fx:id="viewHistory" managed="false" spacing="20.0" visible="false">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
                            </padding>
                            <children>
                                <Label text="Lịch sử đơn hàng">
                                    <font>
                                        <Font name="System Bold" size="22.0"/>
                                    </font>
                                </Label>
                                <TableView fx:id="tblHistory" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colDate" prefWidth="130.0" text="Ngày mua"/>
                                        <TableColumn fx:id="colProduct" prefWidth="180.0" text="Sản phẩm"/>
                                        <TableColumn fx:id="colQuantity" prefWidth="70.0" text="Số lượng"/>
                                        <TableColumn fx:id="colPrice" prefWidth="100.0" text="Đơn giá"/>
                                        <TableColumn fx:id="colTotal" prefWidth="110.0" text="Thành tiền"/>
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox fx:id="viewDeposit" alignment="TOP_CENTER" managed="false" spacing="30.0" visible="false">
                            <padding>
                                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
                            </padding>
                            <children>
                                <Label text="Nạp tiền vào tài khoản">
                                    <font>
                                        <Font name="System Bold" size="22.0"/>
                                    </font>
                                </Label>
                                <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0"
                                      style="-fx-border-color: #27ae60; -fx-border-style: dashed; -fx-border-radius: 15; -fx-background-color: #f9fffb;">
                                    <padding>
                                        <Insets bottom="40.0" left="30.0" right="30.0" top="40.0"/>
                                    </padding>
                                    <children>
                                        <TextField fx:id="txtDepositAmount" alignment="CENTER" prefHeight="50.0"
                                                   promptText="Nhập số tiền ($)" style="-fx-font-size: 18;"/>
                                        <Button onAction="#handleDeposit" prefHeight="45.0" prefWidth="200.0"
                                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                                                text="XÁC NHẬN NẠP"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox fx:id="viewWishlist" managed="false" spacing="20.0" visible="false">
                            <padding>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
                            </padding>
                            <children>
                                <Label text="Sản phẩm yêu thích">
                                    <font>
                                        <Font name="System Bold" size="22.0"/>
                                    </font>
                                </Label>
                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;"
                                            VBox.vgrow="ALWAYS">
                                    <content>
                                        <VBox fx:id="wishlistContainer" spacing="15.0"/>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </HBox>
    </children>
</AnchorPane>